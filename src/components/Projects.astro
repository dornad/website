---
---

<section id="projects">
    <div class="section-header">
        <span class="section-number">02</span>
        <h2 class="section-title">Inventory</h2>
        <div class="section-line"></div>
    </div>

    <div class="projects-filter">
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="ios">iOS</button>
        <button class="filter-btn" data-filter="gamedev">Game Dev</button>
        <button class="filter-btn" data-filter="creative">Creative</button>
    </div>

    <div class="projects-grid">
        <article class="project-card featured" data-category="ios">
            <div class="project-thumb thumb-kitecalc">
                <img
                    src="/images/projects/kitecalc.png"
                    alt="KiteCalc iOS app icon"
                />
            </div>
            <div class="project-body">
                <div class="project-category">iOS &mdash; Indie</div>
                <div class="project-title">KiteCalc</div>
                <div class="project-desc">
                    A kiteboarding gear calculator for iOS. Enter your weight and wind conditions, get recommendations for kite size, board dimensions, and rideable wind ranges. Built with SwiftUI and TCA, powered by an open-source calculation engine. Privacy-first analytics via TelemetryDeck.
                </div>
                <div class="project-tags">
                    <span class="project-tag">Swift</span>
                    <span class="project-tag">SwiftUI</span>
                    <span class="project-tag">TCA</span>
                </div>
            </div>
        </article>

        <article class="project-card" data-category="gamedev creative">
            <div class="project-thumb">
                <img src="/images/projects/repe.png" alt="repe.app screenshot" />
            </div>
            <div class="project-body">
                <div class="project-category">Game Dev &mdash; Indie</div>
                <div class="project-title">repe.app</div>
                <div class="project-desc">
                    Collectible sticker album game engine for the web. Open packs, collect stickers, trade duplicates. Currently powering an ASOIAF fan project.
                </div>
                <div class="project-tags">
                    <span class="project-tag">SvelteKit</span>
                    <span class="project-tag">TypeScript</span>
                </div>
            </div>
        </article>

        <article class="project-card" data-category="ios">
            <div class="project-thumb thumb-light">
                <img
                    src="/images/projects/adapter.svg"
                    alt="Adapter project thumbnail"
                />
            </div>
            <div class="project-body">
                <div class="project-category">iOS &mdash; Adapter</div>
                <div class="project-title">AI Assistant App</div>
                <div class="project-desc">
                    Sole iOS engineer. Built from zero to App Store in under a
                    year. Hybrid native + WebView architecture with AI-native
                    workflow, Share Extension, and SSE streaming.
                </div>
                <div class="project-tags">
                    <span class="project-tag">Swift</span>
                    <span class="project-tag">SwiftUI</span>
                    <span class="project-tag">WebKit</span>
                    <span class="project-tag">SSE</span>
                </div>
            </div>
        </article>

        <article class="project-card" data-category="gamedev">
            <div class="project-thumb">
                <img src="/images/projects/ggj.png" alt="Global Game Jam logo" />
            </div>
            <div class="project-body">
                <div class="project-category">
                    Game Dev &mdash; Global Game Jam
                </div>
                <div class="project-title">Game Jam Collection</div>
                <div class="project-desc">
                    Unbroken streak since 2019. Small teams, 48-hour builds,
                    Godot engine.
                </div>
                <div class="project-tags">
                    <span class="project-tag">Godot</span>
                    <span class="project-tag">GDScript</span>
                    <span class="project-tag">Unity</span>
                    <span class="project-tag">C#</span>
                </div>
            </div>
        </article>

        <article class="project-card" data-category="ios">
            <div class="project-thumb">
                <img
                    src="/images/projects/warby-parker.png"
                    alt="Warby Parker iOS app icon thumbnail"
                />
            </div>
            <div class="project-body">
                <div class="project-category">iOS &mdash; Warby Parker</div>
                <div class="project-title">AR Try-On &amp; Measurements</div>
                <div class="project-desc">
                    Featured by Apple. Worked on AR-powered features,
                    like Virtual Try-On, and internal tools on Apple Platforms.
                </div>
                <div class="project-tags">
                    <span class="project-tag">ARKit</span>
                    <span class="project-tag">RealityKit</span>
                    <span class="project-tag">SceneKit</span>
                </div>
            </div>
        </article>

        <article class="project-card" data-category="ios">
            <div class="project-thumb">
                <img
                    src="/images/projects/homer.png"
                    alt="Learn with Homer iOS app icon thumbnail"
                />
            </div>
            <div class="project-body">
                <div class="project-category">iOS &mdash; Homer Learning</div>
                <div class="project-title">Learn With Homer</div>
                <div class="project-desc">
                    Children&rsquo;s reading app for ages 3&ndash;6. Fun,
                    didactic approach to early literacy.
                </div>
                <div class="project-tags">
                    <span class="project-tag">iOS</span>
                    <span class="project-tag">UIKit</span>
                </div>
            </div>
        </article>

        <article class="project-card" data-category="gamedev">
            <div class="project-thumb">
                <img
                    src="/images/projects/songpop.png"
                    alt="SongPop iOS app icon thumbnail"
                />
            </div>
            <div class="project-body">
                <div class="project-category">Game Dev &mdash; FreshPlanet</div>
                <div class="project-title">SongPop</div>
                <div class="project-desc">
                    #1 Social Game of 2012. BAFTA award winner. Music trivia
                    played by millions.
                </div>
                <div class="project-tags">
                    <span class="project-tag">iOS</span>
                    <span class="project-tag">Android</span>
                    <span class="project-tag">Facebook</span>
                </div>
            </div>
        </article>

        <article class="project-card" data-category="creative">
            <div class="project-thumb">
                <img src="/images/projects/bvw.png" alt="The BVW Show illustration" />
            </div>
            <div class="project-body">
                <div class="project-category">Creative &mdash; CMU ETC</div>
                <div class="project-title">Building Virtual Worlds</div>
                <div class="project-desc">
                    Semester-long interdisciplinary course. Rapid-fire world
                    building with diverse teams.
                </div>
                <div class="project-tags">
                    <span class="project-tag">Panda3D</span>
                    <span class="project-tag">Python</span>
                </div>
            </div>
        </article>
    </div>
</section>

<script>
    const filterBtns = document.querySelectorAll(".filter-btn");
    const projectCards = document.querySelectorAll(".project-card");

    filterBtns.forEach((btn) => {
        btn.addEventListener("click", () => {
            const filter = btn.getAttribute("data-filter");

            filterBtns.forEach((b) => b.classList.remove("active"));
            btn.classList.add("active");

            projectCards.forEach((card) => {
                const category = card.getAttribute("data-category");
                if (filter === "all" || category.includes(filter)) {
                    card.style.display = "";
                } else {
                    card.style.display = "none";
                }
            });
        });
    });
</script>

<style>
    .projects-filter {
        display: flex;
        gap: 0.5rem;
        margin-bottom: 2rem;
    }

    .filter-btn {
        font-family: var(--mono);
        font-size: 0.65rem;
        color: var(--text-dim);
        background: none;
        border: 1px solid var(--border);
        padding: 0.35rem 0.75rem;
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.15s;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .filter-btn:hover {
        color: var(--text-secondary);
        border-color: var(--border-hover);
    }

    .filter-btn.active {
        color: var(--accent);
        border-color: var(--accent);
        background: var(--accent-glow);
    }

    .projects-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.25rem;
    }

    .project-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 8px;
        overflow: hidden;
        transition: all 0.25s;
        cursor: default;
        position: relative;
    }

    .project-card:hover {
        border-color: var(--border-hover);
        transform: translateY(-3px);
        box-shadow: var(--shadow-xl);
    }

    .project-card.featured {
        grid-column: span 2;
    }

    .project-thumb {
        height: 160px;
        background: var(--bg-elevated);
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        opacity: 0.6;
    }

    .project-thumb img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .project-thumb.thumb-light {
        background: var(--thumb-neutral);
    }

    .project-thumb.thumb-light img {
        max-height: 80px;
        object-fit: contain;
    }

    .project-thumb.thumb-kitecalc {
        background: linear-gradient(to bottom, #e8f0fe, #a8d4f0);
    }

    .project-thumb.thumb-kitecalc img {
        max-height: 120px;
        object-fit: contain;
    }

    .project-card.featured .project-thumb {
        height: 200px;
    }

    .project-card[data-category="ios"] .project-thumb {
        border-top: 2px solid var(--accent-blue);
    }

    .project-card[data-category="gamedev"] .project-thumb {
        border-top: 2px solid var(--accent-warm);
    }

    .project-card[data-category="creative"] .project-thumb {
        border-top: 2px solid var(--accent-gold);
    }

    .project-body {
        padding: 1.25rem;
    }

    .project-category {
        font-family: var(--mono);
        font-size: 0.6rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 0.4rem;
    }

    .project-card[data-category="ios"] .project-category {
        color: var(--accent-blue);
    }

    .project-card[data-category="gamedev"] .project-category {
        color: var(--accent-warm);
    }

    .project-card[data-category="creative"] .project-category {
        color: var(--accent-gold);
    }

    .project-title {
        font-family: var(--display);
        font-size: 1.05rem;
        font-weight: 600;
        margin-bottom: 0.4rem;
        letter-spacing: -0.01em;
    }

    .project-desc {
        font-size: 0.8rem;
        color: var(--text-dim);
        line-height: 1.5;
    }

    .project-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
        margin-top: 0.85rem;
    }

    .project-tag {
        font-family: var(--mono);
        font-size: 0.55rem;
        color: var(--text-dim);
        border: 1px solid var(--border);
        padding: 0.15rem 0.45rem;
        border-radius: 3px;
    }

    @media (max-width: 768px) {
        .projects-grid {
            grid-template-columns: 1fr;
        }

        .project-card.featured {
            grid-column: span 1;
        }
    }
</style>